# Copy this file to env.production.local and fill real values.
# Then run:
#   powershell -ExecutionPolicy Bypass -File scripts/vercel/import-env.ps1 -FilePath env.production.local -Environment production

# Use proxy mode for restricted networks:
VITE_SUPABASE_URL=https://YOUR_DOMAIN/api/sb
# Keep backend/server runtime pointed to the real Supabase project:
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_AUTH_REDIRECT_ORIGIN=https://YOUR_DOMAIN
VITE_STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
HEALTHCHECK_TOKEN=CHANGE_ME_LONG_RANDOM

APP_BASE_URL=https://YOUR_DOMAIN
PUBLIC_APP_URL=https://YOUR_DOMAIN

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx

RESEND_API_KEY=re_xxx
MARKETING_FROM_EMAIL=hello@yourdomain.com
MARKETING_FROM_NAME=HustleDesk

UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
