{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/sb/:path*",
      "destination": "/api/sb/[...path]"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/share/:path*",
      "destination": "/"
    },
    {
      "source": "/w/:slug",
      "destination": "/"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/dashboard"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/followup-reminders",
      "schedule": "0 10 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.getsolodesk.com"
        }
      ],
      "destination": "https://getsolodesk.com/",
      "permanent": true
    },
    {
      "source": "/api/sb/:path*/",
      "destination": "/api/sb/:path*",
      "permanent": false
    },
    {
      "source": "/api/:path*/",
      "destination": "/api/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.getsolodesk.com"
        }
      ],
      "destination": "https://getsolodesk.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
