# ---------- Frontend (Vite) ----------
# Use ONE mode:
# 1) Direct mode: https://YOUR_PROJECT.supabase.co
# 2) Proxy mode (for regions where direct Supabase access is blocked): http://localhost:5173/api/sb
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_AUTH_REDIRECT_ORIGIN=http://localhost:5173
# Optional: set true to force browser traffic through /api/sb in production.
VITE_SUPABASE_PROXY_MODE=false
# Optional: set true only if public.users lookup is guaranteed and migrations are applied.
VITE_AUTH_USE_DB_PROFILE_LOOKUP=false
VITE_PORT=5173
VITE_STRIPE_PRICE_ID_PRO_MONTHLY=price_...

# ---------- App API / Server ----------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Optional fallback if primary SUPABASE_URL is unavailable (DNS/network/provider issue)
SUPABASE_FALLBACK_URL=https://YOUR_BACKUP_PROJECT.supabase.co
# Optional additional candidates (comma or whitespace separated)
# SUPABASE_UPSTREAM_URLS=https://first.supabase.co,https://second.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
HEALTHCHECK_TOKEN=SET_A_LONG_RANDOM_TOKEN
CRON_SECRET=SET_A_LONG_RANDOM_TOKEN

# ---------- Stripe ----------
APP_BASE_URL=http://localhost:5173
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...

# ---------- Email marketing (Resend recommended) ----------
# Use ONLY for opt-in marketing. Include unsubscribe links and comply with laws.
PUBLIC_APP_URL=http://localhost:5173
RESEND_API_KEY=re_...
MARKETING_FROM_EMAIL=onboarding@yourdomain.com
MARKETING_FROM_NAME=GetSoloDesk

# ---------- AI ----------
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

